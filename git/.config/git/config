[alias]
	# status / info
	s = status -sb
	st = status
	# staging
	a = add
	aa = add --all
	# commit
	c = commit
	cm = commit -m
	ca = commit --amend
	can = commit --amend --no-edit
	# branches
	b = branch
	co = checkout
	cob = checkout -b
	sw = switch
	# diffs
	d = diff
	ds = diff --staged
	# log — the two most useful
	lg = log --oneline --graph --decorate -20
	lga = log --oneline --graph --decorate --all
	last = show --stat HEAD
	# remote sync
	p = push
	pl = pull
	f = fetch --all --prune
	# undo — unstage a file, keep changes
	unstage = reset HEAD --
	# undo — undo last commit, keep changes staged
	undo = reset --soft HEAD~1
	# what changed, who to blame
	who = shortlog -sne

[init]
	defaultBranch = main

[pull]
	ff = only          # refuse surprise merge commits on pull

[push]
	autoSetupRemote = true   # first push of a new branch sets upstream automatically

[core]
	autocrlf = input   # good default for WSL+macOS: normalize CRLF on commit

# Authenticate GitHub over HTTPS via the gh CLI. Portable: `!gh` resolves on
# PATH (so it works whether gh is in /usr/bin or /opt/homebrew/bin), and the
# empty `helper =` first clears any inherited system helper. Not a secret —
# the token itself lives in gh's own store, not here.
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

# Per-machine identity/signing lives in an uncommitted 'local' file (see
# local.example). Path is absolute with ~ expansion, NOT relative: this
# config file is a symlink into the dotfiles repo, and git resolves a
# relative include against the symlink's target dir (i.e. inside the repo),
# which is not where the per-machine file lives.
[include]
	path = ~/.config/git/local
